# Copy this file to .env in each service folder and update values

# student-service/.env
DATABASE_URL=sqlite:///students.db
DEBUG=True

# course-service/.env
DATABASE_URL=sqlite:///courses.db
DEBUG=True

# enrollment-service/.env
DATABASE_URL=sqlite:///enrollments.db
DEBUG=True
STUDENT_SERVICE_URL=http://localhost:8001
COURSE_SERVICE_URL=http://localhost:8002
TIMEOUT_SECONDS=3
